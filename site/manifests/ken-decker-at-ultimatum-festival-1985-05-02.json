{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://spokenweb.github.io/Ultimatumi1985/manifests/ken-decker-at-ultimatum-festival-1985-05-02.json","type":"Manifest","label":{"en":["Ken Decker at Ultimatum Festival 1985-05-02"]},"homepage":[{"id":"https://spokenweb.github.io/Ultimatumi1985","type":"Text","label":{"en":["Ken Decker at Ultimatum Festival 1985-05-02"]},"format":"text/html"}],"metadata":[{"label":{"en":["Description"]},"value":{"en":["The following is a transcription of Ken Decker’s performance at the Ultimatum Festival I, Thursday, May 2nd, 1985 at the Foufounes Electriques bar and performance space in Montreal, Quebec, Canada. Decker performs poetry while he types, on and off, with long pauses. Decker’s long form experimental prose fiction work was published in 1982 with Quadrant Editions. Decker is cited three times in Alan Lord’s memoir High Friends in Low Places (2022) for his work involving live computer engagement (pp. 125, 127, 200)."]}},{"label":{"en":["Language"]},"value":{"en":["English"]}}],"items":[{"id":"https://spokenweb.github.io/Ultimatumi1985/ken_decker_at_ultimatum_festival_1985_05_02/canvas/9","type":"Canvas","duration":959,"annotations":[{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://spokenweb.github.io/Ultimatumi1985/manifests/ken_decker_at_ultimatum_festival_1985_05_02-canvas9-1","type":"AnnotationPage","label":{"en":["Default"]},"items":[{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://spokenweb.github.io/Ultimatumi1985/ken_decker_at_ultimatum_festival_1985_05_02/canvas/9/page1","body":[{"type":"TextualBody","value":"Performs piece [English] [reads story over typing sounds].","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Ken Decker","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://spokenweb.github.io/Ultimatumi1985/ken_decker_at_ultimatum_fest