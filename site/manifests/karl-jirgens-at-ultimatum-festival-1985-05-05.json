{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://spokenweb.github.io/Ultimatumi1985/manifests/karl-jirgens-at-ultimatum-festival-1985-05-05.json","type":"Manifest","label":{"en":["Karl Jirgens at Ultimatum Festival 1985-05-05"]},"homepage":[{"id":"https://spokenweb.github.io/Ultimatumi1985","type":"Text","label":{"en":["Karl Jirgens at Ultimatum Festival 1985-05-05"]},"format":"text/html"}],"metadata":[{"label":{"en":["Description"]},"value":{"en":["The following is a transcription of Karl Jirgens’ performance at the Ultimatum Festival I, Sunday, May 5th, 1985 at the Foufounes Electriques bar and performance space in Montreal. Jirgens is the author of six books (Travesties, The Razor’s Edge, Eco Blues: A Tale in 3 Parts, A Measure of Time, and Strappado), the former English Department Head and chair of the Creative Writing Program at the University of Windsor, and the founder of Rampike magazine. He is an ELIT awards bronze medalist and his poetry is included in The Best Poetry of Canada (2023). In Alan Lord’s memoir High Friends in Low Places (2022), he writes that Jirgens \"[gave] his reading with a pair of guns pointed at his temples, held by a strap over his head\"."]}},{"label":{"en":["Language"]},"value":{"en":["English"]}}],"items":[{"id":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1","type":"Canvas","duration":1375,"annotations":[{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://spokenweb.github.io/Ultimatumi1985/manifests/karl_jirgens_at_ultimatum_festival_1985_05_05-canvas1-1","type":"AnnotationPage","label":{"en":["Default"]},"items":[{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1/page1","body":[{"type":"TextualBody","value":"Static and light clapping sound.","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Unknown","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1#t=0,1"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1/page1","body":[{"type":"TextualBody","value":"Cuts out, silence.","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Recording","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1#t=1,2"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1/page1","body":[{"type":"TextualBody","value":"Maintenant, uh, Karl Jirgens de la revue Rampike, Toronto.","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Alan Lord","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1#t=2,6"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1/page1","body":[{"type":"TextualBody","value":"Room noise.","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Foufounes Electriques","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://spokenweb.github.io/Ultimatumi1985/karl_jirgens_at_ultimatum_festival_1985_05_05/canvas/1#t=6,22"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","mo