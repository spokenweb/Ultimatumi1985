{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://spokenweb.github.io/Ultimatumi1985/manifests/daniel-guimond-at-ultimatum-festival-1985-05-01.json","type":"Manifest","label":{"en":["Daniel Guimond at Ultimatum Festival 1985-05-01"]},"homepage":[{"id":"https://spokenweb.github.io/Ultimatumi1985","type":"Text","label":{"en":["Daniel Guimond at Ultimatum Festival 1985-05-01"]},"format":"text/html"}],"metadata":[{"label":{"en":["Description"]},"value":{"en":["The following is a transcription of Daniel Guimond’s performance at the Ultimatum Festival I, Wednesday, May 1st, 1985 at the Foufounes Electriques bar and performance space in Montreal, Quebec, Canada. Guimond performs poetry with underlying electric music, recorded sounds, and vocals in English and French. Guimond is a writer and multidisciplinary artist from Montreal. Some of his publications include the novel Pourquoi cela n'arrive qu'a moi ? (1999) and four poetry collections (1997, 1991, 1989, 1978). In his work High Friends in Low Places (2022), Alan Lord mentions Guimond’s punk zine SCRAP and his poetry which he performed while “being whipped” (p.52)."]}},{"label":{"en":["Language"]},"value":{"en":["English"]}}],"items":[{"id":"https://spokenweb.github.io/Ultimatumi1985/daniel_guimond_at_ultimatum_festival_1985_05_01/canvas/17","type":"Canvas","duration":1949,"annotations":[{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://spokenweb.github.io/Ultimatumi1985/manifests/daniel_guimond_at_ultimatum_festival_1985_05_01-canvas17-1","type":"AnnotationPage","label":{"en":["Default"]},"items":[{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://spokenweb.github.io/Ultimatumi1985/daniel_guimond_at_ultimatum_festival_1985_05_01/canvas/17/page1","body":[{"type":"TextualBody","value":"High pitched ringing and background percussion.","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","