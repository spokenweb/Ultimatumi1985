      ],
      "uuid": "8834d456-8eda-4d57-bd2b-a76c99e732ce"
    },
    {
      "start_time": 1834,
      "end_time": 1861,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Film continues [speech: There are spaces that live within us. Spaces which occupy the frame. The transparency of their names. A terrible tragedy that haunts their walls. A revelation of their fiction. Of something which might of happened but that never really occurred]."
            }
          ]
        }
