      "uuid": "5e0fa2c9-c1ee-4a6a-80e4-b4412294eb23"
    },
    {
      "start_time": 1797,
      "end_time": 1834,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Napoleon Moffat’s \"Framed\" starts [piano music]."
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Performers and Speakers",
          "tag": "Napoleon Moffat"
        },
        {
          "tag": "Music",
          "category": "Setting and Tech"
