      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "Bon, Bon soooooooooooir [modulation], bon soir! [left ear] En attendan the John Giorno baaaaaaaand [echo: baaaand][right ear]."
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Performers and Speakers",
